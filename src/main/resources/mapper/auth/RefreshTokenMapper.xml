<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="ko.dh.goot.auth.dao.RefreshTokenMapper">

	<!--  토큰으로 조회 -->
    <select id="findByToken" resultType="ko.dh.goot.auth.domain.RefreshToken" parameterType="String">
        SELECT 
            user_id AS userId,
            token,
            expired_at AS expiredAt,
            revoked
        FROM refresh_token
        WHERE token = #{token}
    </select>

    <!--  유저의 모든 토큰 삭제 -->
    <delete id="deleteByUserId" parameterType="String">
        DELETE FROM refresh_token
        WHERE user_id = #{userId}
    </delete>
    
    <!--  유저의 단일 토큰 삭제 -->
    <delete id="deleteByToken" parameterType="String">
    DELETE FROM refresh_token
    WHERE token = #{token}
	</delete>

    <!--  새 토큰 저장 -->
    <insert id="insertToken" parameterType="ko.dh.goot.auth.domain.RefreshToken">
        INSERT INTO refresh_token (user_id, token, expired_at, revoked)
        VALUES (#{userId}, #{token}, #{expiredAt}, #{revoked})
    </insert>

    <!--  토큰 폐기 -->
    <update id="revokeToken" parameterType="String">
        UPDATE refresh_token
        SET revoked = true
        WHERE token = #{token}
    </update>


</mapper>